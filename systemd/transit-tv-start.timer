[Unit]
Description=Transit TV Graceful Start Timer
Documentation=https://github.com/jasonad123/Transit-TV
Requires=transit-tv-start.service

[Timer]
# Run at 8:00 AM Monday through Friday
# Adjust this time to match your desired startup schedule
OnCalendar=Mon-Fri 08:00:00
Persistent=true

[Install]
WantedBy=timers.target
